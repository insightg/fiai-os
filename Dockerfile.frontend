# Stage 1: Build the React application
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci --only=production=false

COPY . .

# API URL empty = use relative URLs (proxied by nginx)
ENV VITE_API_URL="/api"
ARG VITE_OPENROUTER_API_KEY=""
ENV VITE_OPENROUTER_API_KEY=${VITE_OPENROUTER_API_KEY}

# Build without tsc (skip type checking for faster builds)
RUN npx vite build

# Stage 2: Serve with nginx
FROM nginx:alpine

# Copy nginx template (uses ${BACKEND_HOST} variable)
COPY nginx.conf /etc/nginx/templates/nginx.conf.template
COPY --from=builder /app/dist /usr/share/nginx/html

# Default backend host — overridden per instance via docker-compose
ENV BACKEND_HOST=fiai-backend

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://127.0.0.1:3000/ || exit 1

# nginx:alpine has envsubst built-in via docker-entrypoint.d/20-envsubst-on-templates.sh
# It reads /etc/nginx/templates/*.template and outputs to /etc/nginx/conf.d/
# But we need it at /etc/nginx/nginx.conf, so we do it manually
CMD ["/bin/sh", "-c", "envsubst '${BACKEND_HOST}' < /etc/nginx/templates/nginx.conf.template > /etc/nginx/nginx.conf && nginx -g 'daemon off;'"]
