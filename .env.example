# FIAI OS — Environment Variables
# Copia in instances/{nome}/.env e personalizza

# OpenRouter API key (obbligatoria)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# JWT Secret per autenticazione (obbligatorio)
JWT_SECRET=your-secret-key-change-in-production

# Email (opzionale — necessario per agente email)
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=
EMAIL_SMTP_HOST=

# TTS (opzionale — necessario per agente vocale)
TTS_API_URL=http://host.docker.internal:7777/v1/audio/speech
