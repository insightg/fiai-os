client
dev tun
proto udp
remote hjw0aqjff1h.sn.mynetname.net
port 1195
nobind
persist-key
persist-tun
tls-client
remote-cert-tls server
ca cert_export_CertAuth.crt
cert cert_export_TB-GabrieleGiottoli.crt
key cert_export_TB-GabrieleGiottoli.key
verb 4
data-ciphers AES-256-GCM:AES-128-GCM:AES-256-CBC
cipher AES-256-CBC
##ncp-disable
auth SHA1
auth-user-pass auth.cfg
auth-nocache
##redirect-gateway def1
route-nopull
route 192.168.0.0 255.255.255.0
